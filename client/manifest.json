{
  "name": "NotesNexus",
  "version": "0.0.2",
  "manifest_version": 3,
  "description": "NotesNexus — selectable video text and AI lecture notes",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "NotesNexus",
    "default_icon": "icons/icondefault.png",
    "default_popup": "src/browser_action/browser_action.html"
  },
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*"
  ]
}
